# Calmara 环境配置文件示例
# 复制此文件为 .env 并填入实际值

# ==================== 数据库配置 ====================
POSTGRES_DB=calmara
POSTGRES_USER=calmara
POSTGRES_PASSWORD=calmara_password_change_me

# ==================== Redis配置 ====================
REDIS_PASSWORD=redis_password_change_me

# ==================== API密钥 ====================
WHISPER_API_KEY=whisper_api_key_change_me
MEDIAPIPE_API_KEY=mediapipe_api_key_change_me
VIDEO_API_KEY=video_api_key_change_me
FINETUNE_API_KEY=finetune_api_key_change_me

# ==================== JWT配置 ====================
JWT_SECRET=jwt_secret_key_change_me_to_random_string_at_least_32_chars
JWT_EXPIRATION=86400000

# ==================== 邮件配置 ====================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_email_password
SMTP_FROM=noreply@calmara.local
SMTP_ENABLED=true

# ==================== Ollama配置 ====================
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_FINETUNED_MODEL=qwen2.5-calmara:latest

# ==================== 外部服务配置 ====================
WHISPER_SERVICE_URL=http://whisper-service:8001
MEDIAPIPE_SERVICE_URL=http://mediapipe-service:8002
VIDEO_SERVICE_URL=http://video-service:8003
FINETUNE_SERVICE_URL=http://finetune-service:8004

# ==================== 向量数据库配置 ====================
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=psychology_knowledge

# ==================== 监控配置 ====================
GRAFANA_ADMIN_PASSWORD=grafana_admin_password_change_me
PROMETHEUS_RETENTION=15d

# ==================== 安全配置 ====================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ==================== 存储配置 ====================
UPLOAD_MAX_SIZE=100MB
LOG_LEVEL=INFO
LOG_PATH=/app/logs

# ==================== 情绪分析配置 ====================
EMOTION_TEXT_WEIGHT=0.1
EMOTION_AUDIO_WEIGHT=0.4
EMOTION_VISUAL_WEIGHT=0.4
EMOTION_VIDEO_WEIGHT=0.1
EMOTION_CONFIDENCE_THRESHOLD=0.6

# ==================== 风险评估配置 ====================
RISK_LOW_THRESHOLD=1.0
RISK_MEDIUM_THRESHOLD=2.0
RISK_HIGH_THRESHOLD=3.0
RISK_ALERT_EMAIL_ENABLED=true

# ==================== MCP配置 ====================
MCP_EXCEL_OUTPUT_DIR=/data/excel
MCP_EMAIL_ALERT_RECIPIENTS=counselor@school.edu,admin@school.edu

# ==================== LoRA微调配置 ====================
LORA_BASE_MODEL=Qwen/Qwen2.5-7B-Instruct
LORA_R=16
LORA_ALPHA=32
LORA_DROPOUT=0.05
LORA_LEARNING_RATE=2e-4
LORA_EPOCHS=3

# ==================== 会话配置 ====================
SESSION_TIMEOUT_HOURS=24
EMOTION_HISTORY_TTL_DAYS=30
CHAT_HISTORY_TTL_DAYS=90
